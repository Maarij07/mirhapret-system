<Window x:Class="pos.Views.ReceiptPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt Preview" 
        Height="600" 
        Width="500"
        Background="#f5f5f5"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    
    <Border BorderBrush="#000000" BorderThickness="1">
        <StackPanel Background="#ffffff">
            <!-- Header -->
            <Border Background="#000000" Padding="16,12">
                <TextBlock Text="Receipt Preview" 
                           Foreground="#ffffff" 
                           FontSize="14"
                           FontWeight="Bold"/>
            </Border>

            <!-- Receipt Content -->
            <Border Padding="16" BorderBrush="#e0e0e0" BorderThickness="0,1,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding ReceiptText}" 
                               FontFamily="Courier New"
                               FontSize="11"
                               Foreground="#333333"
                               TextWrapping="Wrap"
                               LineHeight="1.6"/>
                </ScrollViewer>
            </Border>

            <!-- Buttons -->
            <Border Padding="16" BorderBrush="#e0e0e0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" 
                            Content="Close" 
                            Background="#ffffff" 
                            Foreground="#000000"
                            BorderBrush="#000000"
                            BorderThickness="1"
                            FontSize="12"
                            FontWeight="Bold"
                            Padding="0,10"
                            Cursor="Hand"
                            Command="{Binding CloseCommand}"/>
                    <Button Grid.Column="2" 
                            Content="Print Slip" 
                            Background="#000000" 
                            Foreground="#ffffff"
                            FontSize="12"
                            FontWeight="Bold"
                            Padding="0,10"
                            Cursor="Hand"
                            Command="{Binding PrintCommand}"/>
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</Window>
